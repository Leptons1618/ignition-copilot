# ─── LLM Provider ────────────────────────────────────────────────
# "ollama" (default, local) or "github_models" (GitHub Copilot Models API)
LLM_PROVIDER=github_models

# ─── GitHub Models (when LLM_PROVIDER=github_models) ─────────────
# Personal Access Token with models:read scope
# Create at: https://github.com/settings/tokens → Fine-grained → models:read
GITHUB_TOKEN=ghp_your_token_here

# Model ID — see https://github.com/marketplace/models
# Examples: openai/gpt-4.1-mini, openai/gpt-4.1, meta-llama-3.1-8b-instruct
GITHUB_MODELS_MODEL=openai/gpt-4.1-mini

# ─── Ollama (when LLM_PROVIDER=ollama) ───────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ─── Ignition Gateway ───────────────────────────────────────────
IGNITION_URL=http://localhost:8088
IGNITION_PROJECT=ignition-copilot
IGNITION_USER=anish
IGNITION_PASS=developer

# ─── Ignition Project Path (for live view editing) ──────────────
# Point to your Ignition project directory for live Perspective view editing.
# Views are written to: {path}/com.inductiveautomation.perspective/views/
#
# Typical locations:
#   Windows: C:\Program Files\Inductive Automation\Ignition\data\projects\ignition-copilot
#   Linux:   /var/lib/ignition/data/projects/ignition-copilot
#   Docker:  /usr/local/bin/ignition/data/projects/ignition-copilot
IGNITION_PROJECT_PATH=

# ─── Demo mode ───────────────────────────────────────────────────
# Force demo mode (mock data, no gateway required)
# DEMO_MODE=true

# ─── Server ──────────────────────────────────────────────────────
PORT=3001
